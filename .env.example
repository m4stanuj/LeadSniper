# ─── LeadSniper v2.0 Configuration ───────────────────────
# Copy this to .env and fill in your values

# Gmail SMTP (for cold email engine)
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
# Get app password: https://myaccount.google.com/apppasswords

# GitHub API (for B2B lead scraping)
GITHUB_TOKEN=ghp_your_token_here

# Groq API (optional — LLM fallback for pitch generation)
GROQ_API_KEY=gsk_your_key_here

# M4STCLAW Integration (optional — advanced LLM routing)
OPENWORK_CONFIG=path/to/m4stclaw_v3
